    {
      "id": "parse-requisites",
      "name": "Разобрать реквизиты",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 300],
      "parameters": {
        "jsCode": "// Собираем текст\nconst content = $input.item.json.body?.content || [];\nconst text = content\n  .map(el => {\n    if (!el.paragraph) return '';\n    return (el.paragraph.elements || [])\n      .map(e => e.textRun?.content || '')\n      .join('');\n  })\n  .join('\\n');\n\n// Парсим строки формата «Ключ: Значение»\nconst fields = {};\ntext.split('\\n').forEach(line => {\n  const colonIdx = line.indexOf(':');\n  if (colonIdx > 0) {\n    const key = line.substring(0, colonIdx).trim();\n    const val = line.substring(colonIdx + 1).trim();\n    if (key && val) fields[key] = val;\n  }\n});\n\nconst fullName = fields['Полное название'] || fields['Название'] || '';\nconst signatory = fields['ФИО подписанта'] || fields['ФИО'] || fields['Подписант'] || '';\n\nif (!fullName) throw new Error('Не найдено поле \"Полное название\" в документе реквизитов');\nif (!signatory) throw new Error('Не найдено поле \"ФИО подписанта\" в документе реквизитов');\n\nreturn [{ json: { clientName: fullName, signatoryName: signatory } }];"
      }
    },

