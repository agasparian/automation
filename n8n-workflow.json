    {
      "id": "parse-prev-doc",
      "name": "Извлечь номер и дату договора",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300],
      "parameters": {
        "jsCode": "// Собираем весь текст из структуры Google Docs API\nconst content = $input.item.json.body?.content || [];\nconst text = content\n  .map(el => {\n    if (!el.paragraph) return '';\n    return (el.paragraph.elements || [])\n      .map(e => e.textRun?.content || '')\n      .join('');\n  })\n  .join('\\n');\n\n// Номер и дата основного договора: «к Договору № X от Y г.»\nconst matchDogovor = text.match(/к\\s+Договору\\s+№?\\s*([\\w\\/\\-\\.]+)\\s+от\\s+([\\d\\w\\s]+?г\\.)/i);\n\n// Номер приложения: «Приложение № N»\nconst matchNomer = text.match(/Приложение\\s*№\\s*(\\d+)/i);\n\nif (!matchDogovor) throw new Error('Не найдена строка \"к Договору №\" в документе: ' + $input.item.json.title);\nif (!matchNomer)   throw new Error('Не найдена строка \"Приложение №\" в документе: ' + $input.item.json.title);\n\nreturn [{\n  json: {\n    nomerDogovora:    matchDogovor[1].trim(),\n    dataDogovora:     matchDogovor[2].trim(),\n    nomerPrilozhenia: String(parseInt(matchNomer[1]) + 1)\n  }\n}];"
      }
    },

    {
      "id": "extract-requisites-id",
      "name": "Извлечь ID документа реквизитов",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 300],
      "parameters": {
        "jsCode": "let url = '';\ntry { url = $('Новый ответ на форму').first()?.json['Ссылка на файл реквизитов клиента'] || ''; } catch(e) {}\n\nconst match = url.match(/\\/document\\/d\\/([a-zA-Z0-9_-]+)/);\nif (!match) throw new Error('Неверная ссылка на файл реквизитов: ' + url);\nreturn [{ json: { requisitesDocId: match[1] } }];"
      }
    },

